# 复制为 .env 并修改（放在 backend 目录下）
# 服务端口（8000 被占用时可改为 8001 等）
PORT=8000
# 数据库：SQLite（默认）或 MySQL
USE_SQLITE=true
# 使用 MySQL 时设为 false 并配置下方
# USE_SQLITE=false
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=ai_quant_trading
# 初始化 MySQL：python ../scripts/init_mysql.py
SECRET_KEY=your-secret-key-change-in-production
# 实盘 REST 根地址（默认 https://api.gate.com/api/v4）。本机无法解析时可改用：
# GATE_REAL_API_BASE=https://api.gateio.ws/api/v4

# 模拟模式下公共行情（交易对、ticker、K 线优先主站）是否走主站实盘；默认 1 = 看盘用主站价、下单仍用模拟 API。
# 若设为 0，公共行情会走 Testnet（与主站价格可能不一致）。
# GATE_SIMULATED_PUBLIC_USE_REAL=0

# K 线除 GATE_REAL_API_BASE 外自动再试的备用实盘根（默认 api.gateio.ws，与主站不同时才发第二次请求）
# GATE_KLINE_ALT_REAL_BASE=https://api.gateio.ws/api/v4

# 主站与备用均失败时，是否允许合约/现货 K 线回退 Testnet（仅模拟模式；价格非主站实盘）。默认 1；完全不要 Testnet 数据可设为 0
# GATE_KLINE_FALLBACK_TESTNET=0
