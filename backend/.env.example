# 复制为 .env 并修改（放在 backend 目录下）
# 服务端口（8000 被占用时可改为 8001 等）
PORT=8000
# 数据库：SQLite（默认）或 MySQL
USE_SQLITE=true
# 使用 MySQL 时设为 false 并配置下方
# USE_SQLITE=false
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=ai_quant_trading
# 初始化 MySQL：python ../scripts/init_mysql.py
SECRET_KEY=your-secret-key-change-in-production
